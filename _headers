# Security and performance headers for Cloudflare Pages

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()

# Cache static assets
# Using moderate cache duration (1 week) for main assets to allow for updates
/style.css
  Cache-Control: public, max-age=604800, must-revalidate

/script.js
  Cache-Control: public, max-age=604800, must-revalidate

/workers/*
  Cache-Control: public, max-age=604800, must-revalidate

# Vendor libraries can be cached longer (1 year) as they rarely change
/icons/*
  Cache-Control: public, max-age=31536000, immutable

/marked/*
  Cache-Control: public, max-age=31536000, immutable

/markdown-it/*
  Cache-Control: public, max-age=31536000, immutable

/spectre/*
  Cache-Control: public, max-age=31536000, immutable

/modern-normalize/*
  Cache-Control: public, max-age=31536000, immutable

# Cache pages for shorter duration
/pages/*
  Cache-Control: public, max-age=3600
